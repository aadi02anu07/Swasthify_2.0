# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/swasthify"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                        # leave blank if no auth (local dev)
REDIS_REFRESH_TTL=2592000              # 30 days in seconds

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_minimum_32_chars
JWT_EXPIRES_IN=15m                     # access token — short lived
JWT_REFRESH_SECRET=another_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend Origin (for CORS) ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
